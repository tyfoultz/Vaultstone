    "@babel/core": "^7.25.0",
    "@babel/plugin-transform-class-static-block": "^7.28.6",
    "@types/base-64": "^1.0.2",
    "@types/react": "~19.0.10",
    "tailwindcss": "^3.4.17",
    "typescript": "~5.8.3"
