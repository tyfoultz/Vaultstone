{
  "name": "vaultstone",
  "version": "0.0.1",
  "private": true,
  "main": "expo-router/entry",
  "workspaces": [
    "packages/*"
  ],
  "scripts": {
    "start": "expo start",
    "android": "expo start --android",
    "ios": "expo start --ios",
    "web": "expo start --web",
    "build:web": "expo export --platform web",
    "typecheck": "node scripts/check-template-hashes.js && tsc --noEmit",
    "lint": "eslint .",
    "postinstall": "node scripts/patch-metro.js && node scripts/copy-pdf-worker.js"
  },
  "dependencies": {
    "@expo-google-fonts/cinzel": "^0.4.2",
    "@expo-google-fonts/cormorant-garamond": "^0.4.1",
    "@expo-google-fonts/crimson-pro": "^0.4.2",
    "@expo-google-fonts/fraunces": "^0.4.1",
    "@expo-google-fonts/manrope": "^0.4.2",
    "@expo-google-fonts/space-grotesk": "^0.4.1",
    "@react-native-async-storage/async-storage": "^2.1.2",
    "@react-navigation/drawer": "^7.9.8",
    "@supabase/supabase-js": "^2.49.4",
    "base-64": "^1.0.0",
    "expo": "~53.0.0",
    "expo-blur": "~14.1.5",
    "expo-document-picker": "~13.1.6",
    "expo-file-system": "~18.1.0",
    "expo-font": "~13.3.2",
    "expo-image-picker": "~16.1.4",
    "expo-linear-gradient": "~14.1.5",
    "expo-router": "~5.1.11",
    "expo-secure-store": "~14.2.0",
    "expo-sqlite": "~15.2.0",
    "metro": "~0.82.5",
    "metro-source-map": "~0.82.5",
    "nativewind": "4.0.36",
    "pdfjs-dist": "^4.10.38",
    "react": "19.0.0",
    "react-dnd": "^16.0.1",
    "react-dnd-html5-backend": "^16.0.1",
    "react-dom": "19.0.0",
    "react-easy-crop": "^5.5.7",
    "react-markdown": "^10.1.0",
    "react-mosaic-component": "^7.0.0-beta0",
    "react-native": "0.79.6",
    "react-native-blob-util": "^0.24.7",
    "react-native-css-interop": "^0.2.3",
    "react-native-gesture-handler": "~2.24.0",
    "react-native-markdown-display": "^7.0.2",
    "react-native-pdf": "^7.0.4",
